@article{saputra_recognizing_2024,
	title = {Recognizing {Indonesian} sign language ({Bisindo}) gesture in complex backgrounds},
	volume = {36},
	copyright = {http://creativecommons.org/licenses/by-nc/4.0},
	issn = {2502-4760, 2502-4752},
	url = {https://ijeecs.iaescore.com/index.php/IJEECS/article/view/36130},
	doi = {10.11591/ijeecs.v36.i3.pp1583-1593},
	abstract = {Sign language, particularly Indonesian sign language (Bisindo), is vital for deaf individuals, but learning it is challenging. This study aims to develop an automated Bisindo recognition system suitable for diverse backgrounds. Previous research focused on greenscreen backgrounds and struggled with natural or complex backgrounds. To address this problem, the study proposes using Faster region-based convolutional neural networks (RCNN) and YOLOv5 for hand and face detection, MobileNetV2 for feature extraction, and long short-term memory (LSTM) for classification. The system is also designed to focus on computational efficiency. YOLOv5 model achieves the best result with a sentence accuracy (SAcc) of 49.29\% and a word error rate (WER) of 16.42\%, with a computational time of 0.0188 seconds, surpassing the baseline model. Additionally, the system achieved a SacreBLEU score of 67.77\%, demonstrating its effectiveness in Bisindo recognition across various backgrounds. This research improves accessibility for deaf individuals by advancing automated sign language recognition technology.},
	number = {3},
	urldate = {2026-01-24},
	journal = {Indonesian Journal of Electrical Engineering and Computer Science},
	author = {Saputra, Muhammad Alfhi and Rakun, Erdefi},
	month = dec,
	year = {2024},
	pages = {1583},
	file = {Full Text PDF:/Users/ksnugroho/Zotero/storage/X7XVWDLT/Saputra and Rakun - 2024 - Recognizing Indonesian sign language (Bisindo) gesture in complex backgrounds.pdf:application/pdf},
}

@article{ridwang_detecting_2024,
	title = {Detecting signal transtition in dynamic sign language using {R}-{GB} {LSTM} {Method}},
	volume = {10},
	copyright = {https://creativecommons.org/licenses/by-sa/4.0},
	issn = {2548-3161, 2442-6571},
	url = {https://ijain.org/index.php/IJAIN/article/view/1445},
	doi = {10.26555/ijain.v10i2.1445},
	abstract = {The proposed research uses human-computer interaction applications using dynamic signal language. Researchers have made significant progress in developing sign language recognition (SLR) approaches, both static and dynamic. However, the existing systems are superior at recognizing static sign movement, leaving much room for improvement when it comes to continuous sign language interpretation, mainly because of the presence of interlinked signals. In this study, we introduced a new approach that uses a R-GB LSTM model to identify transition signals and delete them in the memory of the system at the time of the training process. Our method relies on breaking the continuous sign indication into separate words and then modeling its words using neural tissue. The remarkable advantage of this approach is that it avoids the need to consider different word combinations during the training process. To evaluate the effectiveness of the proposed method, we conducted an experiment using 20 words in Indonesian sign language (ISL). Twenty representative words were selected for modeling using our LSTM modification technique. The results are promising, with an average accuracy of 80 percent for sign sentences and a more impressive 85 percent accurate rate for sign words. As we look forward, further research paths may explore additional R-GB LSTM modification methods or models to detect and reduce more nuanced interference during training. Our study represents a significant step forward in advancing the accuracy and practicality of sustainable sign language recognition systems, promising better communication and accessibility for deaf and hard-hearing communities.},
	number = {2},
	urldate = {2026-01-24},
	journal = {International Journal of Advances in Intelligent Informatics},
	author = {Ridwang, Ridwang and Adriani, Adriani and Rahmania, Rahmania and Sahrim, Mus’ab and Syahyadi, Asep Indra and Setiaji, Haris},
	month = may,
	year = {2024},
	pages = {348},
	file = {Full Text PDF:/Users/ksnugroho/Zotero/storage/G567M4EI/Ridwang et al. - 2024 - Detecting signal transtition in dynamic sign language using R-GB LSTM Method.pdf:application/pdf},
}

