@article{rakun_word_2022,
	title = {Word recognition and automated epenthesis removal for {Indonesian} sign system sentence gestures},
	volume = {26},
	copyright = {http://creativecommons.org/licenses/by-nc/4.0},
	issn = {2502-4760, 2502-4752},
	url = {http://ijeecs.iaescore.com/index.php/IJEECS/article/view/28190},
	doi = {10.11591/ijeecs.v26.i3.pp1402-1414},
	abstract = {This research {\textless}span{\textgreater}focuses on building a system to translate continuous Indonesian sign system (SIBI) gestures into text. In a continuous gesture, a signer will add an epenthesis (transitional) gesture, which is hand movement with no meaning but needed to connect the hand movement of one word with the next word in a continuous gesture. Reducing the number of irrelevant inputs to the model through automated epenthesis removal can improve the system's ability to recognize the words in continuous gestures. We implemented threshold conditional random fields (TCRF) to identify epenthesis gestures. The dataset consists of 2,255 videos representing 28 common sentences in SIBI. The translation system consists of MobileNetV2 as a feature extraction technique, removing epenthesis gestures found by the TCRF, and a long short-term memory (LSTM) for the classifier. With the MobileNetV2-TCRF-bidirectional LSTM model, the best word error rate (WER) and sentence accuracy (SAcc) were 33.4\% and 16.2\%, respectively. Intermediate-stage processing steps consisting of sandwiched majority voting of the TCRF and the removal of word labels whose number of frames is less than two frames, along with LSTM output grouping, were able to reduce WER from 33.4\% to 3.4\% and increase SAcc from 16.2\% to 80.2\%.{\textless}/span{\textgreater}},
	number = {3},
	urldate = {2026-01-24},
	journal = {Indonesian Journal of Electrical Engineering and Computer Science},
	author = {Rakun, Erdefi and Widhinugraha, I Gusti Bagus Hadi and Putra Setyono, Noer Fitria},
	month = jun,
	year = {2022},
	pages = {1402},
	file = {Full Text:/Users/ksnugroho/Zotero/storage/DZ8TJW9T/Rakun et al. - 2022 - Word recognition and automated epenthesis removal for Indonesian sign system sentence gestures.pdf:application/pdf},
}

